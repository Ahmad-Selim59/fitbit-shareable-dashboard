# Copy to .env.local — see README for setup.

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000/api/auth/google/callback
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Set true while Google Cloud OAuth consent screen is in Testing (7-day token limit)
NEXT_PUBLIC_GOOGLE_OAUTH_TESTING_MODE=true

# Supabase (service role — server only, never expose to client)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# 32-byte key as 64 hex chars: openssl rand -hex 32
TOKEN_ENCRYPTION_KEY=

# Super-admin for /admin — AES-encrypted value (not plaintext)
# Generate: TOKEN_ENCRYPTION_KEY=... node scripts/encrypt-admin-password.mjs "your-password"
ADMIN_PASSWORD=
