# Copy to .env.local — see README for Google Cloud setup.

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000/api/auth/google/callback
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Optional: paste refresh token after one-time /setup (production)
# GOOGLE_REFRESH_TOKEN=

# Optional: password-protect the site when deployed
# DASHBOARD_PASSWORD=
